# Copy to .env for private local use. Keep .env out of commits.
GAITLAB_MODE=public_demo
GAITLAB_USE_MOCK_NODES=true
GAITLAB_ENABLE_SSH=false
GAITLAB_ALLOW_REAL_ROBOT=false

GAITLAB_GPU0_HOST=GPU0
GAITLAB_GPU1_HOST=GPU1
GAITLAB_RESEARCH_PC_HOST=localhost

GAITLAB_TRAIN_HOST_PRIMARY=
GAITLAB_TRAIN_HOST_FALLBACKS=

GAITLAB_ROBOT_HOST=offline_mock
GAITLAB_ROBOT_HOST_FALLBACKS=

GAITLAB_LAB_REPO_PATH=
GAITLAB_WORKSPACE_PATH=
GAITLAB_ARTIFACT_ROOT=demo_data/artifacts
GAITLAB_EVAL_ROOT=demo_data/metrics

GAITLAB_SSH_USER=
GAITLAB_SSH_KEY_PATH=

GAITLAB_OPERATOR_APPROVAL_REQUIRED=true
GAITLAB_ESTOP_DRY_RUN_REQUIRED=true
GAITLAB_LIVE_DEMO_MOCK=false
GAITLAB_USE_GOOGLE_API=false
GAITLAB_GEMINI_MODEL=gemini-3.5-flash
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# ---- Live lab adapter (private use only; never set these for the public demo) ----
# When GAITLAB_ENABLE_SSH=true AND GAITLAB_LAB_REPO_PATH points at a real
# checkout of your private lab repository, GaitLab Agent activates its live
# lab adapter (gaitlab/lab/). In live mode the agent may submit real training
# jobs to GPU0/GPU1 and, when every safety gate AND operator approval AND
# emergency-stop evidence all pass, may deploy a policy to the real robot.
#
# Leave these commented to keep the safe-by-default public demo behavior.
# GAITLAB_MODE=private_lab
# GAITLAB_USE_MOCK_NODES=false
# GAITLAB_ENABLE_SSH=true
# GAITLAB_ALLOW_REAL_ROBOT=false
# GAITLAB_LAB_REPO_PATH=C:\path\to\private-lab-repo
# GAITLAB_OPERATOR_APPROVAL_REQUIRED=true
# GAITLAB_ESTOP_DRY_RUN_REQUIRED=true
# GAITLAB_LIVE_DEMO_MOCK=true  # video-only mode: no SSH, no GPU jobs
# GAITLAB_USE_GOOGLE_API=true   # optional: Gemini-backed experiment design
